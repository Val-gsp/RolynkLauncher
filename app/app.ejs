<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" http-equiv="Content-Security-Policy" content="script-src 'self' 'sha256-In6B8teKZQll5heMl9bS7CESTbGvuAt3VVV86BUQBDk='"/>
    <title><%= lang('app.title') %></title>
    <script src="./assets/js/scripts/uicore.js"></script>
    <script src="./assets/js/scripts/uibinder.js"></script>
    <script src="./assets/js/scripts/bgvideo.js"></script>
    <link type="text/css" rel="stylesheet" href="./assets/css/launcher.css">
    <style>
        body {
            -webkit-user-select: none;
        }
        #bgVideo {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* Zoom ancré en haut (masque le filigrane) + léger décalage vers la droite. */
            transform: scale(1.18) translateX(3%);
            transform-origin: top center;
            z-index: -1;
        }
        #main {
            display: none;
            height: calc(100% - 22px);
            /* Assombrissement : plus marqué en bas, plus les côtés gauche et droit. */
            background:
                linear-gradient(to top, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0) 72%),
                linear-gradient(to right, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 24%),
                linear-gradient(to left, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 24%);
            width: 100%;
            position: absolute;
            z-index: 10;
        }
        #main[overlay] {
            filter: blur(3px) contrast(0.9) brightness(1.0);
        }
    </style>
</head>
<body>
    <!-- La source est fournie par bgvideo.js via une URL blob (voir la note dans ce script). -->
    <video id="bgVideo" autoplay loop muted playsinline disableRemotePlayback></video>
    <%- include('frame') %>
    <div id="main">
        <%- include('welcome') %>
        <%- include('login') %>
        <%- include('waiting') %>
        <%- include('loginOptions') %>
        <%- include('rolynkAuth') %>
        <%- include('settings') %>
        <%- include('landing') %>
    </div>
    <%- include('overlay') %>
    <div id="loadingContainer">
        <div id="loadingContent">
            <div id="loadSpinnerContainer">
                <img id="loadCenterImage" src="assets/images/LoadingSeal.png">
                <img id="loadSpinnerImage" class="rotating" src="assets/images/LoadingText.png">
            </div>
        </div>
    </div>
</body>
</html>